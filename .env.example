# 复制此文件为 .env 并填写您的配置

# ============ DeepSeek API配置 ============
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ============ 备用API配置（可选） ============
SILICON_API_KEY=sk-your-silicon-api-key

# ============ 飞书应用配置 ============
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
FEISHU_APP_TOKEN=xxxxxxxx
FEISHU_TABLE_ID=xxxxxxxx

# ============ 飞书Webhook配置 ============
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ============ 视频制作API配置（可选） ============
YIZHEN_API_KEY=your-yizhen-api-key

# ============ 平台Cookie配置（可选） ============
DOUYIN_COOKIE=your-douyin-cookie
KUAISHOU_COOKIE=your-kuaishou-cookie
XIAOHONGSHU_COOKIE=your-xiaohongshu-cookie

# ============ 系统配置 ============
DAILY_GENERATE_LIMIT=10
